{% extends "layout.twig" %}
{% block title %}Маршрутизация{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="mb-6">
    <h1 class="text-3xl font-bold">Маршрутизация</h1>
    <p class="text-gray-600 mt-2">Каркас индивидуальной маршрутизации. Data plane будет включаться после установки routing-agent.</p>
  </div>

  {% if 'success=' in current_uri %}
    <div class="mb-4 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded">Изменение сохранено.</div>
  {% endif %}
  {% if 'error=' in current_uri %}
    <div class="mb-4 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded">Ошибка сохранения. Проверьте введённые данные.</div>
  {% endif %}

  <div class="grid grid-cols-1 md:grid-cols-6 gap-4 mb-8">
    <div class="bg-white rounded shadow p-4"><div class="text-sm text-gray-500">Ingress</div><div class="text-2xl font-bold">{{ stats.ingresses }}</div></div>
    <div class="bg-white rounded shadow p-4"><div class="text-sm text-gray-500">Links</div><div class="text-2xl font-bold">{{ stats.links }}</div></div>
    <div class="bg-white rounded shadow p-4"><div class="text-sm text-gray-500">IP lists</div><div class="text-2xl font-bold">{{ stats.ip_lists }}</div></div>
    <div class="bg-white rounded shadow p-4"><div class="text-sm text-gray-500">Profiles</div><div class="text-2xl font-bold">{{ stats.profiles }}</div></div>
    <div class="bg-white rounded shadow p-4"><div class="text-sm text-gray-500">Groups</div><div class="text-2xl font-bold">{{ stats.groups }}</div></div>
    <div class="bg-white rounded shadow p-4"><div class="text-sm text-gray-500">Pending</div><div class="text-2xl font-bold">{{ stats.pending_revisions }}</div></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-white rounded shadow p-6">
      <h2 class="font-bold mb-4">Добавить routing ingress</h2>
      <form method="POST" action="/routing/ingresses" class="space-y-3">
        <select name="server_protocol_id" class="w-full px-3 py-2 border rounded" required onchange="const opt=this.options[this.selectedIndex]; document.getElementById('routingServerId').value=opt.dataset.server;">
          <option value="">Выберите установленный протокол</option>
          {% for p in protocols %}
            <option value="{{ p.server_protocol_id }}" data-server="{{ p.server_id }}">{{ p.server_name }} / {{ p.protocol_name }}{% if p.routing_enabled %} (routing enabled){% endif %}</option>
          {% endfor %}
        </select>
        <input type="hidden" name="server_id" id="routingServerId">
        <input name="pool_cidr" class="w-full px-3 py-2 border rounded" placeholder="10.100.1.0/24" required>
        <input name="interface_name" class="w-full px-3 py-2 border rounded" placeholder="awg-r1" required>
        <button class="gradient-bg text-white px-4 py-2 rounded w-full">Сохранить ingress</button>
      </form>
    </div>

    <div class="bg-white rounded shadow p-6">
      <h2 class="font-bold mb-4">Создать server link</h2>
      <form method="POST" action="/routing/links" class="space-y-3">
        <select name="ingress_id" class="w-full px-3 py-2 border rounded" required>
          <option value="">Ingress</option>
          {% for ingress in ingresses %}
            <option value="{{ ingress.id }}">{{ ingress.server_name }} / {{ ingress.protocol_name }} / {{ ingress.pool_cidr }}</option>
          {% endfor %}
        </select>
        <select name="egress_server_id" class="w-full px-3 py-2 border rounded" required>
          <option value="">Egress server</option>
          {% for server in servers %}
            <option value="{{ server.id }}">{{ server.name }} ({{ server.host }})</option>
          {% endfor %}
        </select>
        <input name="name" class="w-full px-3 py-2 border rounded" placeholder="WG1 -> WG2" required>
        <input name="endpoint_host" class="w-full px-3 py-2 border rounded" placeholder="egress.example.test">
        <input name="endpoint_port" type="number" min="1" max="65535" class="w-full px-3 py-2 border rounded" placeholder="51840">
        <select name="user_access_mode" class="w-full px-3 py-2 border rounded">
          <option value="admin_only">admin_only</option>
          <option value="user_allowed">user_allowed</option>
          <option value="disabled">disabled</option>
        </select>
        <button class="gradient-bg text-white px-4 py-2 rounded w-full">Создать link</button>
      </form>
    </div>
  </div>

  <div class="bg-white rounded shadow p-6 mb-8">
    <h2 class="font-bold mb-4">IP-списки</h2>
    <form method="POST" action="/routing/ip-lists" class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-6">
      <input name="name" class="px-3 py-2 border rounded" placeholder="Название списка" required>
      <select name="scope" class="px-3 py-2 border rounded">
        <option value="admin">admin</option>
        <option value="system">system</option>
      </select>
      <textarea name="entries" class="px-3 py-2 border rounded md:col-span-3" rows="4" placeholder="1.1.1.0/24&#10;8.8.8.8/32"></textarea>
      <button class="gradient-bg text-white px-4 py-2 rounded md:col-span-3">Создать список</button>
    </form>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50"><tr><th class="px-4 py-2 text-left">Name</th><th class="px-4 py-2 text-left">Scope</th><th class="px-4 py-2 text-left">Owner</th></tr></thead>
        <tbody>
          {% for list in ip_lists %}
          <tr class="border-t"><td class="px-4 py-2">{{ list.name }}</td><td class="px-4 py-2">{{ list.scope }}</td><td class="px-4 py-2">{{ list.owner_email|default('-') }}</td></tr>
          {% else %}
          <tr><td colspan="3" class="px-4 py-8 text-center text-gray-500">Списков пока нет</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <div class="bg-white rounded shadow p-6 mb-8">
    <h2 class="font-bold mb-4">Группы пользователей</h2>
    <form method="POST" action="/routing/groups" class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-6">
      <input name="name" class="px-3 py-2 border rounded" placeholder="Название группы" required>
      <input name="description" class="px-3 py-2 border rounded md:col-span-2" placeholder="Описание">
      <button class="gradient-bg text-white px-4 py-2 rounded md:col-span-3">Создать группу</button>
    </form>

    <div class="overflow-x-auto mb-6">
      <table class="w-full">
        <thead class="bg-gray-50"><tr><th class="px-4 py-2 text-left">Group</th><th class="px-4 py-2 text-left">Members</th><th class="px-4 py-2 text-left">Status</th></tr></thead>
        <tbody>
          {% for group in routing_groups %}
          <tr class="border-t"><td class="px-4 py-2">{{ group.name }}</td><td class="px-4 py-2">{{ group.member_count }}</td><td class="px-4 py-2">{% if group.enabled %}enabled{% else %}disabled{% endif %}</td></tr>
          {% else %}
          <tr><td colspan="3" class="px-4 py-8 text-center text-gray-500">Групп пока нет</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% for group in routing_groups %}
      <div class="border rounded p-4 mb-4">
        <div class="font-semibold mb-3">{{ group.name }}</div>
        <form method="POST" action="/routing/groups/{{ group.id }}/members" class="mb-4">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2 mb-3">
            {% for routing_user in routing_users %}
              <label class="flex items-center gap-2 text-sm border rounded px-3 py-2">
                <input type="checkbox" name="user_ids[]" value="{{ routing_user.id }}" {% if routing_user.id in group.member_user_ids %}checked{% endif %}>
                <span>{{ routing_user.email }}{% if routing_user.routing_group_id and routing_user.routing_group_id != group.id %} ({{ routing_user.routing_group_name }}){% endif %}</span>
              </label>
            {% endfor %}
          </div>
          <button class="bg-gray-800 text-white px-4 py-2 rounded">Сохранить участников</button>
        </form>

        <form method="POST" action="/routing/groups/{{ group.id }}/permissions" class="grid grid-cols-1 md:grid-cols-6 gap-3">
          <select name="server_link_id" class="px-3 py-2 border rounded md:col-span-2" required>
            <option value="">Server link</option>
            {% for link in links %}
              <option value="{{ link.id }}">{{ link.name }} / {{ link.ingress_server_name }} -> {{ link.egress_server_name }}</option>
            {% endfor %}
          </select>
          <select name="permission" class="px-3 py-2 border rounded">
            <option value="allow">allow</option>
            <option value="deny">deny</option>
          </select>
          <input name="max_routes" type="number" min="1" max="1000" value="100" class="px-3 py-2 border rounded" placeholder="max routes">
          <input name="minimum_prefix_length" type="number" min="0" max="32" value="8" class="px-3 py-2 border rounded" placeholder="min prefix">
          <label class="flex items-center gap-2 px-3 py-2 border rounded text-sm">
            <input type="checkbox" name="allow_default_route" value="1">
            <span>0.0.0.0/0</span>
          </label>
          <button class="gradient-bg text-white px-4 py-2 rounded md:col-span-6">Сохранить право группы</button>
        </form>
      </div>
    {% endfor %}

    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50"><tr><th class="px-4 py-2 text-left">Group</th><th class="px-4 py-2 text-left">Link</th><th class="px-4 py-2 text-left">Permission</th><th class="px-4 py-2 text-left">Limits</th></tr></thead>
        <tbody>
          {% for permission in group_permissions %}
          <tr class="border-t">
            <td class="px-4 py-2">{{ permission.group_name }}</td>
            <td class="px-4 py-2">{{ permission.link_name }} / {{ permission.ingress_server_name }} -> {{ permission.egress_server_name }}</td>
            <td class="px-4 py-2">{{ permission.permission }}</td>
            <td class="px-4 py-2">max {{ permission.max_routes }}, /{{ permission.minimum_prefix_length }}+{% if permission.allow_default_route %}, default route{% endif %}</td>
          </tr>
          {% else %}
          <tr><td colspan="4" class="px-4 py-8 text-center text-gray-500">Групповых прав пока нет</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <div class="bg-white rounded shadow p-6">
    <h2 class="font-bold mb-4">Server links</h2>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50"><tr><th class="px-4 py-2 text-left">Name</th><th class="px-4 py-2 text-left">Ingress</th><th class="px-4 py-2 text-left">Egress</th><th class="px-4 py-2 text-left">Access</th><th class="px-4 py-2 text-left">Status</th></tr></thead>
        <tbody>
          {% for link in links %}
          <tr class="border-t">
            <td class="px-4 py-2">{{ link.name }}</td>
            <td class="px-4 py-2">{{ link.ingress_server_name }}</td>
            <td class="px-4 py-2">{{ link.egress_server_name }}</td>
            <td class="px-4 py-2">{{ link.user_access_mode }}</td>
            <td class="px-4 py-2">{{ link.status }} / {{ link.health_status }}</td>
          </tr>
          {% else %}
          <tr><td colspan="5" class="px-4 py-8 text-center text-gray-500">Links пока нет</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
{% endblock %}

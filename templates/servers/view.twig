          '<span style="color:#991b1b;">' + (err.message || 'Ошибка связи') + '</span></div>';
        setTimeout(() => { btn.innerHTML = origHTML; document.querySelectorAll('.btn-uninstall-sp').forEach(b => { b.disabled = false; b.style.opacity = '1'; }); }, 3000);
      }
    });
  });



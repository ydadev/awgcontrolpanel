+
+    private static function normalizeIds(array $ids): array
+    {
+        $normalized = [];
+        foreach ($ids as $id) {
+            $id = (int) $id;
+            if ($id > 0) {
+                $normalized[$id] = $id;
+            }
+        }
+        return array_values($normalized);
+    }
+}

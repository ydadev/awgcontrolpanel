# Environment Configuration
APP_ENV=local
APP_NAME="AWG Control Panel"
SESSION_NAME=awg_control_panel_session

# Default locale
DEFAULT_LOCALE=ru

# HTTP binding for the test stand.
# Keep 127.0.0.1 and use SSH tunnel for safer testing, or set 0.0.0.0 on an isolated VM.
PANEL_HTTP_BIND=127.0.0.1
PANEL_HTTP_PORT=8082

# Database Configuration
DB_HOST=db
DB_PORT=3306
DB_DATABASE=amnezia_panel
DB_USERNAME=amnezia
DB_PASSWORD=replace-with-random-db-password
DB_ROOT_PASSWORD=replace-with-random-root-password

# Admin Account (auto-created on first run)
ADMIN_EMAIL=admin@example.test
ADMIN_PASSWORD=replace-with-random-admin-password

# API Configuration
JWT_SECRET=replace-with-at-least-32-random-characters
API_RATE_LIMIT=100

# VPN Defaults
DEFAULT_VPN_PORT_MIN=30000
DEFAULT_VPN_PORT_MAX=65000
DEFAULT_VPN_SUBNET=10.8.1.0/24
DEFAULT_DNS=1.1.1.1,1.0.0.1
